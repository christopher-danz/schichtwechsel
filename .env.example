# Copy to .env and fill in values
APP_ENV=development

# Pioneer/Fastino GLiNER2 — needed for from_api() and Day 2 fine-tune eval
# Get at: https://gliner.pioneer.ai
#PIONEER_API_KEY=pk_...
PIONEER_API_KEY=pio_sk_...

# Gradium speech-to-text
# Get at: https://gradium.ai
#GRADIUM_API_KEY=gd_...
GRADIUM_API_KEY=gsk_...

# Use local gliner2-base-v1 (false) or Pioneer cloud API (true)
USE_PIONEER_API=false

# Use fine-tuned LoRA adapter (Day 2 only)
USE_FINETUNED=false

# Anthropic API — used by scripts/generate_training_data.py
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
